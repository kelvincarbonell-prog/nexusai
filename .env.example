NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Proveedores IA (al menos uno). El sistema selecciona el primero disponible
# en este orden para extracción/categorización: OpenAI -> Anthropic -> Gemini -> Groq.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Modelos Claude (opcional, valores por defecto si no se especifican)
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_PRO_MODEL=claude-opus-4-5

# Token compartido para validar el webhook de email entrante (Postmark/Mailgun/SendGrid).
# Si no se configura, el endpoint /api/inbound/email queda público — configúralo en producción.
INBOUND_EMAIL_SECRET=

# Dominio donde apuntan los alias de buzón único por empresa.
NEXT_PUBLIC_INBOX_DOMAIN=inbox.nexusai.app
