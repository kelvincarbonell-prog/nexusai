NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# PROVEEDORES IA — al menos uno con visión para OCR
# =============================================================================
# El sistema intenta proveedores en este orden y se queda con el primero que
# devuelva respuesta válida:
#   1. Gemini flash (gratis, visión)             → GEMINI_API_KEY
#   2. Mistral Pixtral 12B (gratis, visión)      → MISTRAL_API_KEY
#   3. OpenRouter Llama Vision free              → OPENROUTER_API_KEY
#   4. OpenRouter Gemini Flash free              → mismo OPENROUTER_API_KEY
#   5. OCR.space + Groq (texto extraído)         → OCRSPACE_API_KEY + GROQ_API_KEY
#   6. Groq llama (solo texto)                   → GROQ_API_KEY
#   7. OpenAI / Anthropic (de pago)              → OPENAI_API_KEY / ANTHROPIC_API_KEY
#
# RECOMENDADO (todo gratuito):
#   GEMINI_API_KEY      → https://aistudio.google.com/app/apikey
#   MISTRAL_API_KEY     → https://console.mistral.ai/api-keys (free tier)
#   OPENROUTER_API_KEY  → https://openrouter.ai/keys (modelos :free)
#   GROQ_API_KEY        → https://console.groq.com/keys
#   OCRSPACE_API_KEY    → https://ocr.space/ocrapi/freekey (25k req/mes)
# =============================================================================
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
OCRSPACE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Modelos Gemini (opcional)
# Por defecto AMBOS apuntan a flash porque la mayoría de keys solo tienen acceso
# a flash, no a pro.
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-flash

# Modelos Mistral (opcional)
MISTRAL_FAST_MODEL=pixtral-12b-2409
# MISTRAL_PRO_MODEL=pixtral-large-latest   # solo si tienes acceso (de pago)

# Modelo por defecto en OpenRouter (cualquier modelo de openrouter.ai)
OPENROUTER_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# Modelos Claude (opcional)
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_PRO_MODEL=claude-opus-4-5

# Token compartido para validar el webhook de email entrante (Postmark/Mailgun/SendGrid).
# Si no se configura, el endpoint /api/inbound/email queda público — configúralo en producción.
INBOUND_EMAIL_SECRET=

# Dominio donde apuntan los alias de buzón único por empresa.
NEXT_PUBLIC_INBOX_DOMAIN=inbox.nexusai.app

# Stripe (cobros con un clic — opcional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel Cron (autenticación de los crons)
CRON_SECRET=
