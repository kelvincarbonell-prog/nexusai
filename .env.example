NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# PROVEEDORES IA — al menos uno
# =============================================================================
# Para OCR de facturas (requiere visión): necesitas GEMINI o OpenAI o Anthropic.
# Groq SOLO sirve para texto (no procesa imágenes).
# Para texto/JSON: cualquiera de los 4 vale.
#
# Recomendación: GEMINI_API_KEY + GROQ_API_KEY (gratuitas/baratas, cubren todo).
# Orden de fallback: Gemini flash → Groq llama 70B → Groq llama 8B → OpenAI → Anthropic.
# =============================================================================
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Modelos Gemini (opcional)
# Por defecto AMBOS apuntan a flash porque la mayoría de keys solo tienen acceso
# a flash, no a pro. Solo configura GEMINI_PRO_MODEL si tu key tiene acceso a pro.
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-flash

# Modelos Claude (opcional, solo si tienes ANTHROPIC_API_KEY)
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_PRO_MODEL=claude-opus-4-5

# Token compartido para validar el webhook de email entrante (Postmark/Mailgun/SendGrid).
# Si no se configura, el endpoint /api/inbound/email queda público — configúralo en producción.
INBOUND_EMAIL_SECRET=

# Dominio donde apuntan los alias de buzón único por empresa.
NEXT_PUBLIC_INBOX_DOMAIN=inbox.nexusai.app

# Stripe (cobros con un clic — opcional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel Cron (autenticación de los crons)
CRON_SECRET=
